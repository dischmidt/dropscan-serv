#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/.venv/bin/python"
ENTRYPOINT="$SCRIPT_DIR/dropscan.py"

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "Virtual environment Python not found at: $VENV_PYTHON" >&2
  echo "Create it with: python -m venv .venv" >&2
  echo "Then install deps with: .venv/bin/python -m pip install -r requirements.txt" >&2
  exit 1
fi

if [[ ! -f "$ENTRYPOINT" ]]; then
  echo "Entry point not found at: $ENTRYPOINT" >&2
  exit 1
fi

exec "$VENV_PYTHON" "$ENTRYPOINT" "$@"
